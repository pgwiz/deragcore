# API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
AZURE_API_KEY=your-azure-key-here
AZURE_ENDPOINT=https://your-region.openai.azure.com/
AZURE_DEPLOYMENT_NAME=deploy-name
OPENAI_API_KEY=sk-your-key-here

# Database
DATABASE_URL=postgresql+asyncpg://ragcore:ragcore@localhost:5432/ragcore

# Cache
REDIS_URL=redis://localhost:6379/0

# App Settings
LOG_LEVEL=DEBUG
WORKERS=1
PORT=8000
ENV=development

# Feature Flags
ENABLE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434

# ========== PHASE 2: File Processing & Chat ==========
# File Limits
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_SESSION=100

# Chunking
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# Embedding (Azure: phi-4, llama-3.3, qwen-2.5 or OpenAI: text-embedding-3-small)
EMBEDDING_PROVIDER=azure
EMBEDDING_MODEL=phi-4
EMBEDDING_BATCH_SIZE=10

# Chat History
PRESERVE_ALL_HISTORY=true
CHAT_HISTORY_LIMIT=1000

# Background Jobs
JOB_TIMEOUT_SECONDS=300
JOB_MAX_RETRIES=3
JOB_CHECK_INTERVAL_MS=500
